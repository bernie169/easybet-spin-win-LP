import { Menu, Mail, ShieldCheck, Radio, Wallet, ChevronRight } from 'lucide-react';

const TRACKING_BASE = 'https://ebpartners.click/o/lWk0jB?lpage=UCblAk';

function buildTrackingLink(): string {
  if (typeof window === 'undefined') return TRACKING_BASE;
  const params = new URLSearchParams(window.location.search);
  const t1 = params.get('t1');
  const s1 = params.get('s1');
  const extra: string[] = [];
  if (t1) extra.push('t1=' + encodeURIComponent(t1));
  if (s1) extra.push('s1=' + encodeURIComponent(s1));
  if (extra.length === 0) return TRACKING_BASE;
  return TRACKING_BASE + '&' + extra.join('&');
}

